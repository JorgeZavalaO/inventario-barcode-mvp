generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  COUNTER
  VIEWER
}

enum SessionStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  CANCELLED
}

enum InputMethod {
  CAMERA
  MANUAL
  USB
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(COUNTER)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @map("session_token") @id
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id               String          @id @default(uuid())
  code             String          @unique
  barcode          String?         @unique
  description      String
  unit             String          @default("UND")
  category         String?
  theoreticalStock Decimal         @default(0) @map("theoretical_stock") @db.Decimal(14, 3)
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  sessionProducts  SessionProduct[]
  countEvents      CountEvent[]
  barcodes         ProductBarcode[]
  packages         ProductPackage[]
  locationStocks   ProductLocationStock[]

  @@map("products")
}

model ProductBarcode {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  value     String  @unique
  type      String  @default("EAN13")
  active    Boolean @default(true)
  createdAt DateTime @default(now())

  product  Product          @relation(fields: [productId], references: [id])
  packages ProductPackage[]

  @@index([productId])
  @@map("product_barcodes")
}

model ProductPackage {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  code         String
  name         String
  baseQuantity Decimal  @map("base_quantity") @db.Decimal(14, 3)
  barcodeId    String?  @map("barcode_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  product Product       @relation(fields: [productId], references: [id])
  barcode ProductBarcode? @relation(fields: [barcodeId], references: [id])

  @@unique([productId, code])
  @@map("product_packages")
}

model ProductLocationStock {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  positionId       String   @map("position_id")
  theoreticalStock Decimal  @map("theoretical_stock") @db.Decimal(14, 3)
  minimumStock     Decimal? @map("minimum_stock") @db.Decimal(14, 3)
  isPrimary        Boolean  @default(false) @map("is_primary")
  source           String?
  sourceUpdatedAt  DateTime? @map("source_updated_at")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product  Product          @relation(fields: [productId], references: [id])
  position StoragePosition  @relation(fields: [positionId], references: [id])

  @@unique([productId, positionId])
  @@index([positionId])
  @@map("product_location_stocks")
}

model Operator {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  sessionParticipants SessionParticipant[]
  countEvents         CountEvent[]

  @@map("operators")
}

model InventorySession {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  warehouse     String          @default("Almacén principal")
  status        SessionStatus   @default(OPEN)
  schemaVersion Int             @default(1) @map("schema_version")
  createdAt     DateTime        @default(now()) @map("created_at")
  closedAt      DateTime?       @map("closed_at")

  sessionProducts      SessionProduct[]
  sessionParticipants  SessionParticipant[]
  countEvents          CountEvent[]

  @@map("inventory_sessions")
}

model SessionProduct {
  sessionId        String   @map("session_id")
  productId        String   @map("product_id")
  theoreticalStock Decimal  @default(0) @map("theoretical_stock") @db.Decimal(14, 3)

  session InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@id([sessionId, productId])
  @@map("session_products")
}

model SessionParticipant {
  sessionId  String   @map("session_id")
  operatorId String   @map("operator_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  session  InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  operator Operator         @relation(fields: [operatorId], references: [id], onDelete: Restrict)

  @@id([sessionId, operatorId])
  @@map("session_participants")
}

model CountEvent {
  id           String      @id @default(uuid())
  operationId  String      @unique @map("operation_id")
  sessionId    String      @map("session_id")
  productId    String      @map("product_id")
  operatorId   String      @map("operator_id")
  quantity     Decimal     @db.Decimal(14, 3)
  inputMethod  InputMethod @default(CAMERA) @map("input_method")
  createdAt    DateTime    @default(now()) @map("created_at")
  reversedAt   DateTime?   @map("reversed_at")

  session  InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product  Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  operator Operator         @relation(fields: [operatorId], references: [id], onDelete: Restrict)

  @@index([sessionId, productId])
  @@index([sessionId, createdAt(sort: Desc)])
  @@map("count_events")
}

enum DepthKind {
  FRONT
  MIDDLE
  BACK
  CUSTOM
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floors Floor[]

  @@map("warehouses")
}

model Floor {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  code        String
  name        String
  orderIndex  Int      @map("order_index")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  zones     WarehouseZone[]

  @@unique([warehouseId, code])
  @@map("floors")
}

model WarehouseZone {
  id         String   @id @default(uuid())
  floorId    String   @map("floor_id")
  code       String
  name       String
  type       String?
  orderIndex Int      @map("order_index")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  floor Floor @relation(fields: [floorId], references: [id])
  racks Rack[]

  @@unique([floorId, code])
  @@map("warehouse_zones")
}

model Rack {
  id         String   @id @default(uuid())
  zoneId     String   @map("zone_id")
  code       String
  name       String
  widthMm    Int?     @map("width_mm")
  heightMm   Int?     @map("height_mm")
  depthMm    Int?     @map("depth_mm")
  orderIndex Int      @map("order_index")
  active     Boolean  @default(true)
  version    Int      @default(1)
  design     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  zone         WarehouseZone     @relation(fields: [zoneId], references: [id])
  compartments RackCompartment[]
  positions    StoragePosition[]

  @@unique([zoneId, code])
  @@map("racks")
}

model RackCompartment {
  id          String   @id @default(uuid())
  rackId      String   @map("rack_id")
  code        String
  name        String
  x           Int
  y           Int
  width       Int
  height      Int
  moduleLabel String?  @map("module_label")
  levelLabel  String?  @map("level_label")
  orderIndex  Int      @map("order_index")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rack       Rack            @relation(fields: [rackId], references: [id])
  depthSlots RackDepthSlot[]
  positions  StoragePosition[]

  @@unique([rackId, code])
  @@map("rack_compartments")
}

model RackDepthSlot {
  id            String    @id @default(uuid())
  compartmentId String    @map("compartment_id")
  code          String
  name          String
  kind          DepthKind
  depthIndex    Int       @map("depth_index")
  startZ        Int?      @map("start_z")
  depthSize     Int?      @map("depth_size")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  compartment RackCompartment  @relation(fields: [compartmentId], references: [id])
  positions   StoragePosition[]

  @@unique([compartmentId, code])
  @@map("rack_depth_slots")
}

model StoragePosition {
  id            String   @id @default(uuid())
  rackId        String   @map("rack_id")
  compartmentId String   @map("compartment_id")
  depthSlotId   String   @map("depth_slot_id")
  code          String   @unique
  qrValue       String   @unique @map("qr_value")
  capacityQty   Decimal? @map("capacity_qty") @db.Decimal(14, 3)
  capacityUnit  String?  @map("capacity_unit")
  active        Boolean  @default(true)
  countable     Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rack          Rack                  @relation(fields: [rackId], references: [id])
  compartment   RackCompartment       @relation(fields: [compartmentId], references: [id])
  depthSlot     RackDepthSlot         @relation(fields: [depthSlotId], references: [id])
  locationStocks ProductLocationStock[]

  @@index([rackId])
  @@index([compartmentId])
  @@index([depthSlotId])
  @@map("storage_positions")
}
