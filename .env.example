# Base de datos (Neon PostgreSQL, Supabase o local vía Prisma)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Auth.js - Genera un secreto con: openssl rand -base64 32
AUTH_SECRET="genera-un-secreto-aqui"
AUTH_URL="http://localhost:3000"

# Feature flags
# Habilita la funcionalidad de inventario con ubicaciones físicas V2
INVENTORY_LOCATION_V2_ENABLED=false
